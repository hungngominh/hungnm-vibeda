<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS Reverse Proxy config for hungnm-vibeda.allianceits.com
  Requirements:
    - IIS Application Request Routing (ARR) 3.0
    - IIS URL Rewrite 2.0
    - WebSocket Protocol feature (IIS > Server > Add Roles > Web Server > Application Development > WebSocket Protocol)
    - ARR Proxy enabled: IIS Manager > Server > Application Request Routing Cache > Server Proxy Settings > Enable proxy
-->
<configuration>
  <system.webServer>

    <!-- Enable IIS WebSocket handler so ARR can proxy upgrade requests -->
    <webSocket enabled="true" />

    <rewrite>
      <rules>
        <!-- All HTTP(S) requests are proxied to the Docker container on port 3000 -->
        <rule name="ReverseProxy" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://localhost:3000/{R:1}" />
          <serverVariables>
            <!-- Preserve original host header so the app knows the public domain -->
            <set name="HTTP_X_FORWARDED_HOST" value="{HTTP_HOST}" />
            <!-- Set forwarded protocol (change to https if TLS is terminated at IIS) -->
            <set name="HTTP_X_FORWARDED_PROTO" value="http" />
          </serverVariables>
        </rule>
      </rules>
    </rewrite>

    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="X-Content-Type-Options" value="nosniff" />
      </customHeaders>
    </httpProtocol>

  </system.webServer>
</configuration>
